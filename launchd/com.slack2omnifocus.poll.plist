<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.slack2omnifocus.poll</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/sh</string>
        <string>-c</string>
        <string>set -a; . /Users/dan/slack2omnifocus/.env.local; exec /Users/dan/.local/bin/slack2omnifocus poll</string>
    </array>

    <key>StartInterval</key>
    <integer>300</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/slack2omnifocus.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/slack2omnifocus.stderr.log</string>
</dict>
</plist>
